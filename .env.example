ENV=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# SQLite local default:
# DATABASE_URL=sqlite:///./data/facebook_scraper.db

# PostgreSQL local/server:
DATABASE_URL=postgresql://scraper:change_this_password@localhost:5432/facebook_scraper

# PostgreSQL URL used by the API container inside Docker Compose:
API_DATABASE_URL=postgresql://scraper:change_this_password@postgres:5432/facebook_scraper

SECRET_KEY=change-me
ENCRYPTION_KEY=change-me
SCHEDULER_ENABLED=True

# Docker Compose PostgreSQL defaults. Change these before exposing the DB.
POSTGRES_USER=scraper
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=facebook_scraper
POSTGRES_PORT=5432
